{
  backend_autoconnect: on
  backend_foreground_suspend: 600
  backend_monitor: on
  backend_notification_cooldown: 300
  backend_notify_co2: on
  backend_notify_humidity: off
  backend_notify_lux: on
  backend_notify_temperature: off
  backend_poll_interval: 30
  connect: disconnected
  functionKey: on
  gui_bus_interval: 1000ms
  gui_bus_samples: 3
  gui_key_0_action: None
  gui_key_1_action: None
  gui_key_2_action: None
  gui_key_3_action: None
  gui_key_4_action: None
  gui_oled_layout: Clock + status
  gui_read_interval: 1000ms
  gui_sensor_samples: 3
  gui_temperature_unit: Celsius (C)
  gui_wireless: off
  gui_wireless_enabled: on
  history_limit: 256
  history_visual_size: 16
  language: español
  last_connection: COM49
  log_level: DEBUG
  terminal_color: on
  terminal_cols: 180
  terminal_lines: 48
  terminal_palette: dark
}
